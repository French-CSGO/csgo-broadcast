PORT=8181

# MySQL — même base get5 que tournament-stats
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=get5
DB_PASS=yourpassword
DB_NAME=get5

# Token auth — doit correspondre à tv_broadcast_origin_auth sur tous les serveurs CS
BROADCAST_AUTH=SuperSecureStringDoNotShare

# Préfixe pour retrouver le serveur dans get5 :
# slug "CS2-Tournament-1.1" → last part "1.1" → display_name "CS 1.1"
SERVER_PREFIX=CS

# Nombre de fragments à bufferiser avant de servir aux viewers
FRAG_DELAY=10

# Minutes d'inactivité avant de considérer un broadcast comme terminé
TIMEONLINE=5
